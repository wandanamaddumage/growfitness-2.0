PORT=<PORT>
MONGODB_URI=<MONGODB_URI>

# JWT configuration
JWT_SECRET=<JWT_SECRET>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET>
JWT_EXPIRES_IN=<JWT_EXPIRES_IN>
JWT_REFRESH_EXPIRES_IN=<JWT_REFRESH_EXPIRES_IN>

# Frontend origin(s) allowed by CORS (comma-separated)
CORS_ORIGIN=<CORS_ORIGIN>

# Support chat (OpenAI) — server only, do not expose in frontend
OPENAI_API_KEY=<OPENAI_API_KEY>

# Email configuration (Gmail SMTP)
EMAIL_ENABLED=<EMAIL_ENABLED>
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=<SMTP_PORT>
SMTP_USER=<SMTP_USER>
SMTP_PASSWORD=<SMTP_PASSWORD>
SMTP_FROM=<SMTP_FROM>

# WhatsApp (Twilio). TWILIO_WHATSAPP_FROM = E.164 number or whatsapp:+1234567890
# WHATSAPP_DEFAULT_COUNTRY_CODE = country code for numbers starting with 0 (default 94)
WHATSAPP_ENABLED=<WHATSAPP_ENABLED>
TWILIO_ACCOUNT_SID=<TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<TWILIO_AUTH_TOKEN>
TWILIO_WHATSAPP_FROM=<TWILIO_WHATSAPP_FROM>
WHATSAPP_DEFAULT_COUNTRY_CODE=94