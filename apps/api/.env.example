PORT=<PORT>
MONGODB_URI=<MONGODB_URI>

# JWT & Authentication
JWT_SECRET=<JWT_SECRET>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET>
JWT_EXPIRES_IN=<JWT_EXPIRES_IN>
JWT_REFRESH_EXPIRES_IN=<JWT_REFRESH_EXPIRES_IN>
# Password reset token expiry in seconds (default: 3600)
PASSWORD_RESET_TOKEN_EXPIRY=3600

# Public URL of the parent/coach web app (password reset links, coach welcome email login link)
# Production example: https://client-growfitness.vercel.app
CLIENT_WEB_URL=http://localhost:5173
# Optional legacy alias for CLIENT_WEB_URL
# FRONTEND_URL=

# Frontend origin(s) allowed by CORS (pipe-separated, e.g. https://client-growfitness.vercel.app|http://localhost:5173)
CORS_ORIGIN=<CORS_ORIGIN>

# GCS file uploads (signed URLs from API; browser uploads directly to bucket)
# Create bucket with scripts/gcs-uploads-setup.sh and grant the Cloud Run runtime SA:
#   roles/storage.objectAdmin on the bucket (or minimal: create + delete objects)
# For signing URLs on Cloud Run / GCE (no JSON key), the runtime SA MUST have
# roles/iam.serviceAccountTokenCreator on itself: principal = that SA email, member = same SA.
# Without this, POST /uploads/presign returns 5xx (IAM signBlob PERMISSION_DENIED).
# (or use a dedicated signing key — see Google Cloud signed URL docs).
GCS_BUCKET_NAME=<GCS_BUCKET_NAME>
# Optional: public base URL for objects (e.g. https://cdn.example.com or https:<bucket>.storage.googleapis.com)
# If unset, URLs use https://storage.googleapis.com/<bucket>/...
GCS_PUBLIC_BASE_URL=
# Optional: explicit GCP project for @google-cloud/storage (Cloud Run usually infers it)
GCP_PROJECT_ID=
# Local development only: absolute path to a service account JSON file.
# Do not commit the JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Support chat (OpenAI) — server only, do not expose in frontend
OPENAI_API_KEY=<OPENAI_API_KEY>

# Google Calendar (OAuth)
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
# OAuth callback URL on the API (e.g. http://localhost:3000/api/auth/google/calendar/callback)
GOOGLE_CALENDAR_REDIRECT_URI=<GOOGLE_CALENDAR_REDIRECT_URI>
# Optional: secret used to sign OAuth state (defaults to JWT_SECRET)
GOOGLE_OAUTH_STATE_SECRET=<GOOGLE_OAUTH_STATE_SECRET>

# Email configuration (Gmail SMTP)
EMAIL_ENABLED=<EMAIL_ENABLED>
SMTP_HOST=<SMTP_HOST>
SMTP_PORT=<SMTP_PORT>
SMTP_USER=<SMTP_USER>
SMTP_PASSWORD=<SMTP_PASSWORD>
SMTP_FROM=<SMTP_FROM>

WHATSAPP_DEFAULT_COUNTRY_CODE=94

# Invoice PDF (Puppeteer).
# Linux / Docker: install Chromium and set path (see apps/api/Dockerfile), e.g. PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# macOS / Windows local dev: defaults to system Google Chrome (channel "chrome") when neither var is set.
# If you prefer Puppeteer's downloaded Chrome instead: pnpm puppeteer:install-chrome (from apps/api)
# PUPPETEER_EXECUTABLE_PATH=
# PUPPETEER_CHANNEL=chrome

# Text.lk SMS
TEXTLK_ENABLED=<TEXTLK_ENABLED>
TEXTLK_API_TOKEN=<TEXTLK_API_TOKEN>
TEXTLK_SENDER_ID=<TEXTLK_SENDER_ID>
